rules_version = '2';

// Security rules for the AvareX Community feature.
//
// Deploy with:
//   firebase deploy --only firestore:rules
//
// Threat model and known limitations (must read before changing):
//
//   * No Cloud Functions. v1 is rules-only. The two long-term gaps that
//     cannot be closed with rules alone are:
//       (a) counter integrity (memberCount / postCount can be bumped by
//           ±1 per call by any signed-in user; rules cannot prove that a
//           bump is paired with a sibling membership/post write in the
//           same batch). The rule below caps the damage at exactly ±1
//           per call and forbids negatives, but the counts can still
//           drift under adversarial use. Long term, move counters to a
//           Cloud Function trigger or compute on read via aggregate
//           queries.
//       (b) Spoofed createdAt / joinedAt timestamps. We only validate
//           that the field is a timestamp, not that it equals
//           request.time. Migrate to FieldValue.serverTimestamp() once
//           we add a Cloud Function or accept a small drift.
//
//   * Group documents are readable by any signed-in pilot so that the
//     Discover tab can surface private groups by name (the join-request
//     flow needs this). Do NOT put invite codes, moderation notes, or
//     any other secret in the group doc -- put them in a subcollection
//     with stricter rules.
//
// Indexes required:
//   - groups: (visibility ASC, memberCount DESC) -- declared in
//     firestore.indexes.json. The name-prefix search uses the auto
//     single-field index on nameLower.

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // Auth helpers
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // =========================================================
    // Group helpers
    // =========================================================

    function groupData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }

    function isGroupOwner(gid) {
      return isSignedIn() && groupData(gid).ownerUid == request.auth.uid;
    }

    function groupVisibility(gid) {
      return groupData(gid).visibility;
    }

    function memberData(gid, uid) {
      return get(
        /databases/$(database)/documents/groups/$(gid)/members/$(uid)
      ).data;
    }

    function memberExists(gid, uid) {
      return exists(
        /databases/$(database)/documents/groups/$(gid)/members/$(uid)
      );
    }

    function isActiveMember(gid) {
      return isSignedIn()
        && memberExists(gid, request.auth.uid)
        && memberData(gid, request.auth.uid).status == 'active';
    }

    // =========================================================
    // Validation helpers
    // =========================================================

    function isValidIcao(v) {
      return v == null || (v is string && v.size() <= 4);
    }

    function isValidStringList(v, maxItems) {
      return v is list && v.size() <= maxItems;
    }

    function isValidTimestamp(v) {
      return v is timestamp;
    }

    // Counter delta gate. Allows any signed-in caller to bump memberCount
    // or postCount by exactly +1 or -1, and forbids any other field
    // change. Counts can never go negative. This is the v1 compromise for
    // not having Cloud Functions; see the file-level comment.
    function isCounterBumpOnly() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly(['memberCount', 'postCount'])
        && request.resource.data.memberCount is int
        && request.resource.data.postCount is int
        && request.resource.data.memberCount >= 0
        && request.resource.data.postCount >= 0
        && (!('memberCount' in changed)
            || request.resource.data.memberCount
               == resource.data.memberCount + 1
            || request.resource.data.memberCount
               == resource.data.memberCount - 1)
        && (!('postCount' in changed)
            || request.resource.data.postCount
               == resource.data.postCount + 1
            || request.resource.data.postCount
               == resource.data.postCount - 1);
    }

    // =========================================================
    // Pilot profiles
    // =========================================================

    function isValidProfile() {
      return request.resource.data.keys().hasOnly([
        'displayName', 'displayNameLower', 'homeAirport',
        'ratings', 'aircraftTypes', 'bio',
        'createdAt', 'updatedAt'
      ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.displayNameLower is string
        && request.resource.data.displayNameLower.size() <= 40
        && isValidIcao(request.resource.data.get('homeAirport', null))
        && isValidStringList(request.resource.data.get('ratings', []), 12)
        && isValidStringList(
             request.resource.data.get('aircraftTypes', []), 12)
        && (request.resource.data.get('bio', null) == null
            || (request.resource.data.bio is string
                && request.resource.data.bio.size() <= 200))
        && isValidTimestamp(request.resource.data.createdAt)
        && isValidTimestamp(request.resource.data.updatedAt);
    }

    match /users/{uid} {
      // Profiles are readable by any signed-in pilot so member lists and
      // post-author avatars work. Sensitive future fields must NOT live
      // on this doc -- create a separate restricted subcollection.
      allow read: if isSignedIn();

      allow create, update: if isSelf(uid) && isValidProfile();

      allow delete: if false;
    }

    // =========================================================
    // Groups
    // =========================================================

    function isValidGroupCreate() {
      return request.resource.data.keys().hasOnly([
        'name', 'nameLower', 'description', 'homeAirport',
        'tags', 'visibility',
        'ownerUid', 'ownerName',
        'memberCount', 'postCount', 'createdAt'
      ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && isValidIcao(request.resource.data.get('homeAirport', null))
        && isValidStringList(request.resource.data.get('tags', []), 12)
        && request.resource.data.visibility in ['public', 'private']
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40
        && request.resource.data.memberCount == 1
        && request.resource.data.postCount == 0
        && isValidTimestamp(request.resource.data.createdAt);
    }

    // Owner-only metadata edit. Owner cannot transfer ownership or
    // rewrite createdAt; everything else is permitted but stays inside
    // the same key whitelist as create.
    function isValidOwnerGroupUpdate() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return request.resource.data.keys().hasOnly([
          'name', 'nameLower', 'description', 'homeAirport',
          'tags', 'visibility',
          'ownerUid', 'ownerName',
          'memberCount', 'postCount', 'createdAt'
        ])
        && !('ownerUid' in changed)
        && !('createdAt' in changed)
        && request.resource.data.visibility in ['public', 'private']
        && request.resource.data.memberCount >= 0
        && request.resource.data.postCount >= 0;
    }

    match /groups/{gid} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidGroupCreate();

      allow update: if (isGroupOwner(gid) && isValidOwnerGroupUpdate())
                       || isCounterBumpOnly();

      allow delete: if isGroupOwner(gid);

      // -----------------------------------------------------
      // Members
      // -----------------------------------------------------

      function isValidMemberDoc() {
        return request.resource.data.keys().hasOnly([
          'displayName', 'homeAirport', 'role', 'status', 'joinedAt'
        ])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 60
          && isValidIcao(request.resource.data.get('homeAirport', null))
          && request.resource.data.role in ['owner', 'member']
          && request.resource.data.status in ['active', 'pending']
          && isValidTimestamp(request.resource.data.joinedAt);
      }

      match /members/{uid} {
        // Member rosters are exposed in three legitimate cases. Private
        // group rosters are NOT browseable by strangers -- that closes
        // the social-graph enumeration leak.
        allow read: if isSignedIn() && (
          isSelf(uid)
          || isGroupOwner(gid)
          || groupVisibility(gid) == 'public'
          || isActiveMember(gid)
        );

        // Only self-create paths. There is no owner-creates-other-user
        // branch; approvals happen via update of an existing pending
        // doc that the joiner wrote.
        allow create: if isSelf(uid) && isValidMemberDoc() && (
          // Owner self-create during the group-creation batch.
          // NB: get(group) returns nothing here because the group doc
          // is being created in the same batch, so we cannot consult
          // visibility -- this branch is the only safe way to seed the
          // owner's own membership.
          (request.resource.data.role == 'owner'
           && request.resource.data.status == 'active')

          // Public group: join immediately as active member.
          || (request.resource.data.role == 'member'
              && groupVisibility(gid) == 'public'
              && request.resource.data.status == 'active')

          // Private group: pending until owner approves.
          || (request.resource.data.role == 'member'
              && groupVisibility(gid) == 'private'
              && request.resource.data.status == 'pending')
        );

        // Owner-only approval. Only the status field may change, and
        // only from pending -> active. Role and joinedAt are frozen.
        allow update: if isGroupOwner(gid)
          && request.resource.data.diff(resource.data).changedKeys()
               .hasOnly(['status'])
          && resource.data.status == 'pending'
          && request.resource.data.status == 'active';

        // Self may leave; owner may kick. Rules cannot distinguish
        // "owner leaves" from "owner deletes group" (which legitimately
        // batch-deletes the owner's own membership), so the client
        // repository enforces "owners cannot leave -- they must delete
        // the group instead".
        allow delete: if isSelf(uid) || isGroupOwner(gid);
      }

      // -----------------------------------------------------
      // Posts
      // -----------------------------------------------------

      function isValidPost() {
        return request.resource.data.keys().hasOnly([
          'authorUid', 'authorName', 'text', 'attachedAirport',
          'attachedRouteText', 'attachedRouteName',
          'mediaUrls',
          'createdAt'
        ])
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() <= 60
          && request.resource.data.text is string
          // Post body may be empty when a photo or shared plan carries
          // the payload; the client still requires at least one of the
          // three to be non-empty.
          && request.resource.data.text.size() <= 1000
          && isValidIcao(
               request.resource.data.get('attachedAirport', null))
          // Shared flight plan: space-separated waypoint IDs that match
          // PlanRoute.toString / PlanRoute.fromLine. Length capped to
          // keep the post doc small.
          && (request.resource.data.get('attachedRouteText', null) == null
              || (request.resource.data.attachedRouteText is string
                  && request.resource.data.attachedRouteText.size() <= 500))
          && (request.resource.data.get('attachedRouteName', null) == null
              || (request.resource.data.attachedRouteName is string
                  && request.resource.data.attachedRouteName.size() <= 60))
          // Image download URLs (HTTPS, from Firebase Storage). Capped
          // at 4 entries; individual size limits are enforced by the
          // Storage rules.
          && isValidStringList(
               request.resource.data.get('mediaUrls', []), 4)
          && isValidTimestamp(request.resource.data.createdAt);
      }

      match /posts/{pid} {
        allow read: if isSignedIn() && (
          groupVisibility(gid) == 'public'
          || isActiveMember(gid)
          || isGroupOwner(gid)
        );

        allow create: if isActiveMember(gid) && isValidPost();

        allow delete: if isSignedIn() && (
          resource.data.authorUid == request.auth.uid
          || isGroupOwner(gid)
        );

        // No edits in v1.
        allow update: if false;
      }
    }

    // =========================================================
    // Denormalized "my groups" index
    // =========================================================

    function isValidUserGroupDoc() {
      return request.resource.data.keys().hasOnly([
        'role', 'status', 'joinedAt', 'groupName'
      ])
        && request.resource.data.role in ['owner', 'member']
        && request.resource.data.status in ['active', 'pending']
        && isValidTimestamp(request.resource.data.joinedAt)
        && request.resource.data.groupName is string
        && request.resource.data.groupName.size() <= 60;
    }

    match /userGroups/{uid}/groups/{gid} {
      allow read: if isSelf(uid);
      allow create, update: if (isSelf(uid) || isGroupOwner(gid))
                              && isValidUserGroupDoc();
      allow delete: if isSelf(uid) || isGroupOwner(gid);
    }

    // =========================================================
    // Aircraft Scheduler
    //
    // Mirrors the Community group model: an owner creates a scheduler,
    // members join (public = immediate, private = owner-approved), the
    // owner adds schedulable resources (aircraft / instructors), and
    // members reserve those resources. Reservations carry a backup queue;
    // when a main reservation is cancelled the next backup is promoted by
    // the canceller via a constrained update (isReservationPromotion).
    //
    // Same rules-only compromises as Community apply (counter drift,
    // client-supplied timestamps, and a small booking race window).
    // =========================================================

    function schedGroupData(sgid) {
      return get(/databases/$(database)/documents/schedulerGroups/$(sgid)).data;
    }

    function isSchedOwner(sgid) {
      return isSignedIn() && schedGroupData(sgid).ownerUid == request.auth.uid;
    }

    function schedVisibility(sgid) {
      return schedGroupData(sgid).visibility;
    }

    function schedMemberData(sgid, uid) {
      return get(
        /databases/$(database)/documents/schedulerGroups/$(sgid)/members/$(uid)
      ).data;
    }

    function schedMemberExists(sgid, uid) {
      return exists(
        /databases/$(database)/documents/schedulerGroups/$(sgid)/members/$(uid)
      );
    }

    function isSchedActiveMember(sgid) {
      return isSignedIn()
        && schedMemberExists(sgid, request.auth.uid)
        && schedMemberData(sgid, request.auth.uid).status == 'active';
    }

    function isValidSchedGroupCreate() {
      return request.resource.data.keys().hasOnly([
        'name', 'nameLower', 'description', 'homeAirport', 'visibility',
        'ownerUid', 'ownerName', 'memberCount', 'resourceCount',
        'maxReservationsPerMember', 'maxWeekendReservations', 'createdAt'
      ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && isValidIcao(request.resource.data.get('homeAirport', null))
        // All schedulers are private.
        && request.resource.data.visibility == 'private'
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40
        && request.resource.data.memberCount == 1
        && request.resource.data.resourceCount == 0
        && request.resource.data.maxReservationsPerMember is int
        && request.resource.data.maxReservationsPerMember >= 0
        && request.resource.data.maxWeekendReservations is int
        && request.resource.data.maxWeekendReservations >= 0
        && isValidTimestamp(request.resource.data.createdAt);
    }

    // ±1 counter bump (memberCount on join/leave). Mirrors the Community
    // isCounterBumpOnly compromise but covers resourceCount too.
    function isSchedCounterBumpOnly() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly(['memberCount', 'resourceCount'])
        && request.resource.data.memberCount is int
        && request.resource.data.resourceCount is int
        && request.resource.data.memberCount >= 0
        && request.resource.data.resourceCount >= 0
        && (!('memberCount' in changed)
            || request.resource.data.memberCount
               == resource.data.memberCount + 1
            || request.resource.data.memberCount
               == resource.data.memberCount - 1)
        && (!('resourceCount' in changed)
            || request.resource.data.resourceCount
               == resource.data.resourceCount + 1
            || request.resource.data.resourceCount
               == resource.data.resourceCount - 1);
    }

    function isValidSchedOwnerUpdate() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return request.resource.data.keys().hasOnly([
          'name', 'nameLower', 'description', 'homeAirport', 'visibility',
          'ownerUid', 'ownerName', 'memberCount', 'resourceCount',
          'maxReservationsPerMember', 'maxWeekendReservations', 'createdAt'
        ])
        && !('ownerUid' in changed)
        && !('createdAt' in changed)
        && request.resource.data.visibility == 'private'
        && request.resource.data.memberCount >= 0
        && request.resource.data.resourceCount >= 0
        && request.resource.data.maxReservationsPerMember is int
        && request.resource.data.maxReservationsPerMember >= 0
        && request.resource.data.maxWeekendReservations is int
        && request.resource.data.maxWeekendReservations >= 0;
    }

    match /schedulerGroups/{sgid} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidSchedGroupCreate();

      allow update: if (isSchedOwner(sgid) && isValidSchedOwnerUpdate())
                       || isSchedCounterBumpOnly();

      allow delete: if isSchedOwner(sgid);

      // -----------------------------------------------------
      // Members
      // -----------------------------------------------------

      function isValidSchedMemberDoc() {
        return request.resource.data.keys().hasOnly([
          'displayName', 'role', 'status', 'joinedAt'
        ])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 60
          && request.resource.data.role in ['owner', 'member']
          && request.resource.data.status in ['active', 'pending']
          && isValidTimestamp(request.resource.data.joinedAt);
      }

      match /members/{uid} {
        allow read: if isSignedIn() && (
          isSelf(uid)
          || isSchedOwner(sgid)
          || schedVisibility(sgid) == 'public'
          || isSchedActiveMember(sgid)
        );

        allow create: if isSelf(uid) && isValidSchedMemberDoc() && (
          (request.resource.data.role == 'owner'
           && request.resource.data.status == 'active')

          || (request.resource.data.role == 'member'
              && schedVisibility(sgid) == 'public'
              && request.resource.data.status == 'active')

          || (request.resource.data.role == 'member'
              && schedVisibility(sgid) == 'private'
              && request.resource.data.status == 'pending')
        );

        allow update: if isSchedOwner(sgid)
          && request.resource.data.diff(resource.data).changedKeys()
               .hasOnly(['status'])
          && resource.data.status == 'pending'
          && request.resource.data.status == 'active';

        allow delete: if isSelf(uid) || isSchedOwner(sgid);
      }

      // -----------------------------------------------------
      // Resources (owner-managed)
      // -----------------------------------------------------

      function isValidResource() {
        return request.resource.data.keys().hasOnly([
          'name', 'type', 'identifier', 'available', 'createdAt'
        ])
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 40
          && request.resource.data.type in ['aircraft', 'instructor']
          && (request.resource.data.get('identifier', null) == null
              || (request.resource.data.identifier is string
                  && request.resource.data.identifier.size() <= 20))
          && request.resource.data.available is bool
          && isValidTimestamp(request.resource.data.createdAt);
      }

      match /resources/{rid} {
        allow read: if isSignedIn() && (
          schedVisibility(sgid) == 'public'
          || isSchedActiveMember(sgid)
          || isSchedOwner(sgid)
        );

        allow create, update: if isSchedOwner(sgid) && isValidResource();

        allow delete: if isSchedOwner(sgid);
      }

      // -----------------------------------------------------
      // Reservations
      // -----------------------------------------------------

      function isValidReservation() {
        return request.resource.data.keys().hasOnly([
          'resourceId', 'resourceName', 'schedulerUid', 'schedulerName',
          'start', 'end', 'isBackup', 'backupOrder', 'note', 'createdAt'
        ])
          && request.resource.data.resourceId is string
          && request.resource.data.resourceName is string
          && request.resource.data.resourceName.size() <= 40
          && request.resource.data.schedulerUid == request.auth.uid
          && request.resource.data.schedulerName is string
          && request.resource.data.schedulerName.size() <= 40
          && isValidTimestamp(request.resource.data.start)
          && isValidTimestamp(request.resource.data.end)
          && request.resource.data.isBackup is bool
          && request.resource.data.backupOrder is int
          && request.resource.data.backupOrder >= 0
          && (request.resource.data.get('note', null) == null
              || (request.resource.data.note is string
                  && request.resource.data.note.size() <= 200))
          && isValidTimestamp(request.resource.data.createdAt);
      }

      // Promotion-only update: a backup becomes the main reservation when
      // the previous main is cancelled. The canceller (any active member)
      // may only flip isBackup false and zero backupOrder; no other field
      // may change. v1 rules-only compromise.
      function isReservationPromotion() {
        return request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly(['isBackup', 'backupOrder'])
          && resource.data.isBackup == true
          && request.resource.data.isBackup == false
          && request.resource.data.backupOrder == 0;
      }

      match /reservations/{resvId} {
        allow read: if isSignedIn() && (
          schedVisibility(sgid) == 'public'
          || isSchedActiveMember(sgid)
          || isSchedOwner(sgid)
        );

        allow create: if isSchedActiveMember(sgid) && isValidReservation();

        allow update: if isSchedOwner(sgid)
                         || (isSchedActiveMember(sgid)
                             && isReservationPromotion());

        // Only the member who booked it or the owner may cancel.
        allow delete: if isSignedIn() && (
          resource.data.schedulerUid == request.auth.uid
          || isSchedOwner(sgid)
        );
      }
    }

    function isValidUserSchedGroupDoc() {
      return request.resource.data.keys().hasOnly([
        'role', 'status', 'joinedAt', 'groupName'
      ])
        && request.resource.data.role in ['owner', 'member']
        && request.resource.data.status in ['active', 'pending']
        && isValidTimestamp(request.resource.data.joinedAt)
        && request.resource.data.groupName is string
        && request.resource.data.groupName.size() <= 60;
    }

    match /userSchedulerGroups/{uid}/groups/{sgid} {
      allow read: if isSelf(uid);
      allow create, update: if (isSelf(uid) || isSchedOwner(sgid))
                              && isValidUserSchedGroupDoc();
      allow delete: if isSelf(uid) || isSchedOwner(sgid);
    }
  }
}
