rules_version = '2';

// Security rules for the AvareX Community feature.
//
// Deploy with:
//   firebase deploy --only firestore:rules
//
// Threat model and known limitations (must read before changing):
//
//   * No Cloud Functions. v1 is rules-only. The two long-term gaps that
//     cannot be closed with rules alone are:
//       (a) counter integrity (memberCount / postCount can be bumped by
//           ±1 per call by any signed-in user; rules cannot prove that a
//           bump is paired with a sibling membership/post write in the
//           same batch). The rule below caps the damage at exactly ±1
//           per call and forbids negatives, but the counts can still
//           drift under adversarial use. Long term, move counters to a
//           Cloud Function trigger or compute on read via aggregate
//           queries.
//       (b) Spoofed createdAt / joinedAt timestamps. We only validate
//           that the field is a timestamp, not that it equals
//           request.time. Migrate to FieldValue.serverTimestamp() once
//           we add a Cloud Function or accept a small drift.
//
//   * Group documents are readable by any signed-in pilot so that the
//     Discover tab can surface private groups by name (the join-request
//     flow needs this). Do NOT put invite codes, moderation notes, or
//     any other secret in the group doc -- put them in a subcollection
//     with stricter rules.
//
// Indexes required:
//   - groups: (visibility ASC, memberCount DESC) -- declared in
//     firestore.indexes.json. The name-prefix search uses the auto
//     single-field index on nameLower.

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // Auth helpers
    // =========================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // =========================================================
    // Group helpers
    // =========================================================

    function groupData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }

    function isGroupOwner(gid) {
      return isSignedIn() && groupData(gid).ownerUid == request.auth.uid;
    }

    function groupVisibility(gid) {
      return groupData(gid).visibility;
    }

    function memberData(gid, uid) {
      return get(
        /databases/$(database)/documents/groups/$(gid)/members/$(uid)
      ).data;
    }

    function memberExists(gid, uid) {
      return exists(
        /databases/$(database)/documents/groups/$(gid)/members/$(uid)
      );
    }

    function isActiveMember(gid) {
      return isSignedIn()
        && memberExists(gid, request.auth.uid)
        && memberData(gid, request.auth.uid).status == 'active';
    }

    // =========================================================
    // Validation helpers
    // =========================================================

    function isValidIcao(v) {
      return v == null || (v is string && v.size() <= 4);
    }

    function isValidStringList(v, maxItems) {
      return v is list && v.size() <= maxItems;
    }

    function isValidTimestamp(v) {
      return v is timestamp;
    }

    // Counter delta gate. Allows any signed-in caller to bump memberCount
    // or postCount by exactly +1 or -1, and forbids any other field
    // change. Counts can never go negative. This is the v1 compromise for
    // not having Cloud Functions; see the file-level comment.
    function isCounterBumpOnly() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly(['memberCount', 'postCount'])
        && request.resource.data.memberCount is int
        && request.resource.data.postCount is int
        && request.resource.data.memberCount >= 0
        && request.resource.data.postCount >= 0
        && (!('memberCount' in changed)
            || request.resource.data.memberCount
               == resource.data.memberCount + 1
            || request.resource.data.memberCount
               == resource.data.memberCount - 1)
        && (!('postCount' in changed)
            || request.resource.data.postCount
               == resource.data.postCount + 1
            || request.resource.data.postCount
               == resource.data.postCount - 1);
    }

    // =========================================================
    // Pilot profiles
    // =========================================================

    function isValidProfile() {
      return request.resource.data.keys().hasOnly([
        'displayName', 'displayNameLower', 'homeAirport',
        'ratings', 'aircraftTypes', 'bio',
        'createdAt', 'updatedAt'
      ])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 40
        && request.resource.data.displayNameLower is string
        && request.resource.data.displayNameLower.size() <= 40
        // Bind the search index to the display name so it can't be spoofed
        // to surface under an unrelated search term (impersonation).
        && request.resource.data.displayNameLower
           == request.resource.data.displayName.lower()
        && isValidIcao(request.resource.data.get('homeAirport', null))
        && isValidStringList(request.resource.data.get('ratings', []), 12)
        && isValidStringList(
             request.resource.data.get('aircraftTypes', []), 12)
        && (request.resource.data.get('bio', null) == null
            || (request.resource.data.bio is string
                && request.resource.data.bio.size() <= 200))
        && isValidTimestamp(request.resource.data.createdAt)
        && isValidTimestamp(request.resource.data.updatedAt);
    }

    // Global uniqueness of the display name: the caller must hold the
    // usernames/{displayNameLower} claim (see the /usernames rules below).
    // This is what actually prevents impersonation -- binding createdByName /
    // authorName to the profile is only meaningful if the profile name itself
    // can't be duplicated. Because rules read committed state, the client
    // claims the username in a separate write *before* writing the profile.
    function ownsUsername(nameLower) {
      return exists(/databases/$(database)/documents/usernames/$(nameLower))
        && get(/databases/$(database)/documents/usernames/$(nameLower)).data.uid
           == request.auth.uid;
    }

    match /users/{uid} {
      // Profiles are readable by any signed-in pilot so member lists and
      // post-author avatars work. Sensitive future fields must NOT live
      // on this doc -- create a separate restricted subcollection.
      allow read: if isSignedIn();

      allow create, update: if isSelf(uid)
        && isValidProfile()
        && ownsUsername(request.resource.data.displayNameLower);

      allow delete: if false;
    }

    // Display-name uniqueness registry. The doc id is the lowercased display
    // name; the doc just records the owning uid. Create-only (no overwrite)
    // guarantees a name can be held by exactly one pilot at a time; a pilot
    // may release (delete) their own claim when renaming. Names here must
    // match the profile's 2-40 char constraint.
    match /usernames/{nameLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid
        && nameLower.size() >= 2 && nameLower.size() <= 40
        && nameLower == nameLower.lower();
      // A claim can never be reassigned in place; the holder must delete then
      // re-create, which keeps ownership unambiguous.
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // =========================================================
    // Groups
    // =========================================================

    function isValidGroupCreate() {
      return request.resource.data.keys().hasOnly([
        'name', 'nameLower', 'description', 'homeAirport',
        'tags', 'visibility',
        'ownerUid', 'ownerName',
        'memberCount', 'postCount', 'createdAt'
      ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && isValidIcao(request.resource.data.get('homeAirport', null))
        && isValidStringList(request.resource.data.get('tags', []), 12)
        && request.resource.data.visibility in ['public', 'private']
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40
        && request.resource.data.memberCount == 1
        && request.resource.data.postCount == 0
        && isValidTimestamp(request.resource.data.createdAt);
    }

    // Owner-only metadata edit. Owner cannot transfer ownership or
    // rewrite createdAt; everything else is permitted but stays inside
    // the same key whitelist as create.
    function isValidOwnerGroupUpdate() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return request.resource.data.keys().hasOnly([
          'name', 'nameLower', 'description', 'homeAirport',
          'tags', 'visibility',
          'ownerUid', 'ownerName',
          'memberCount', 'postCount', 'createdAt'
        ])
        && !('ownerUid' in changed)
        && !('createdAt' in changed)
        // Re-validate the same field types/lengths as create so an owner
        // can't write an oversized or wrong-typed name/description/etc.
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && isValidIcao(request.resource.data.get('homeAirport', null))
        && isValidStringList(request.resource.data.get('tags', []), 12)
        && request.resource.data.visibility in ['public', 'private']
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40
        && request.resource.data.memberCount >= 0
        && request.resource.data.postCount >= 0;
    }

    match /groups/{gid} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidGroupCreate();

      allow update: if (isGroupOwner(gid) && isValidOwnerGroupUpdate())
                       || (isSignedIn() && isCounterBumpOnly());

      allow delete: if isGroupOwner(gid);

      // -----------------------------------------------------
      // Members
      // -----------------------------------------------------

      function isValidMemberDoc() {
        return request.resource.data.keys().hasOnly([
          'displayName', 'homeAirport', 'role', 'status', 'joinedAt'
        ])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 60
          && isValidIcao(request.resource.data.get('homeAirport', null))
          && request.resource.data.role in ['owner', 'member']
          && request.resource.data.status in ['active', 'pending']
          && isValidTimestamp(request.resource.data.joinedAt);
      }

      match /members/{uid} {
        // Member rosters are exposed in three legitimate cases. Private
        // group rosters are NOT browseable by strangers -- that closes
        // the social-graph enumeration leak.
        allow read: if isSignedIn() && (
          isSelf(uid)
          || isGroupOwner(gid)
          || groupVisibility(gid) == 'public'
          || isActiveMember(gid)
        );

        // Only self-create paths. There is no owner-creates-other-user
        // branch; approvals happen via update of an existing pending
        // doc that the joiner wrote.
        allow create: if isSelf(uid) && isValidMemberDoc() && (
          // Owner self-create. During the group-creation batch the group
          // doc isn't committed yet, so !exists() is true and the creator
          // can seed their own owner membership. After the group exists,
          // ONLY the real owner can write an owner member doc -- this
          // closes the bypass where any signed-in user could self-seed an
          // active owner membership into any group.
          (request.resource.data.role == 'owner'
           && request.resource.data.status == 'active'
           && (!exists(/databases/$(database)/documents/groups/$(gid))
               || groupData(gid).ownerUid == request.auth.uid))

          // Public group: join immediately as active member.
          || (request.resource.data.role == 'member'
              && groupVisibility(gid) == 'public'
              && request.resource.data.status == 'active')

          // Private group: pending until owner approves.
          || (request.resource.data.role == 'member'
              && groupVisibility(gid) == 'private'
              && request.resource.data.status == 'pending')
        );

        // Owner-only approval. Only the status field may change, and
        // only from pending -> active. Role and joinedAt are frozen.
        allow update: if isGroupOwner(gid)
          && request.resource.data.diff(resource.data).changedKeys()
               .hasOnly(['status'])
          && resource.data.status == 'pending'
          && request.resource.data.status == 'active';

        // Self may leave; owner may kick. Rules cannot distinguish
        // "owner leaves" from "owner deletes group" (which legitimately
        // batch-deletes the owner's own membership), so the client
        // repository enforces "owners cannot leave -- they must delete
        // the group instead".
        allow delete: if isSelf(uid) || isGroupOwner(gid);
      }

      // -----------------------------------------------------
      // Posts
      // -----------------------------------------------------

      function isValidPost() {
        return request.resource.data.keys().hasOnly([
          'authorUid', 'authorName', 'text', 'attachedAirport',
          'attachedRouteText', 'attachedRouteName',
          'mediaUrls',
          'replyToId', 'replyCount',
          'createdAt'
        ])
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() <= 60
          && request.resource.data.text is string
          // Post body may be empty when a photo or shared plan carries
          // the payload; the client still requires at least one of the
          // three to be non-empty.
          && request.resource.data.text.size() <= 1000
          && isValidIcao(
               request.resource.data.get('attachedAirport', null))
          // Shared flight plan: space-separated waypoint IDs that match
          // PlanRoute.toString / PlanRoute.fromLine. Length capped to
          // keep the post doc small.
          && (request.resource.data.get('attachedRouteText', null) == null
              || (request.resource.data.attachedRouteText is string
                  && request.resource.data.attachedRouteText.size() <= 500))
          && (request.resource.data.get('attachedRouteName', null) == null
              || (request.resource.data.attachedRouteName is string
                  && request.resource.data.attachedRouteName.size() <= 60))
          // Image download URLs (HTTPS, from Firebase Storage). Capped
          // at 4 entries; individual size limits are enforced by the
          // Storage rules.
          && isValidStringList(
               request.resource.data.get('mediaUrls', []), 4)
          // Threading: replyToId is null for a top-level topic, or the
          // (string) id of the topic this post replies to. New posts
          // always start with replyCount == 0; it is bumped only via the
          // constrained update below.
          && (request.resource.data.get('replyToId', null) == null
              || (request.resource.data.replyToId is string
                  && request.resource.data.replyToId.size() <= 64))
          && request.resource.data.get('replyCount', 0) == 0
          && isValidTimestamp(request.resource.data.createdAt);
      }

      // The only post mutation allowed: bumping a topic's replyCount by
      // exactly ±1 when a reply is created or deleted. Mirrors the group
      // isCounterBumpOnly compromise -- rules can't prove the bump is
      // paired with a sibling reply write, so the count can drift under
      // adversarial use, but the per-call damage is capped at ±1 and the
      // count can never go negative. get(..., 0) tolerates legacy topics
      // that predate the replyCount field.
      function isReplyCountBumpOnly() {
        let changed =
          request.resource.data.diff(resource.data).changedKeys();
        return changed.hasOnly(['replyCount'])
          && request.resource.data.replyCount is int
          && request.resource.data.replyCount >= 0
          && (request.resource.data.replyCount
                == resource.data.get('replyCount', 0) + 1
              || request.resource.data.replyCount
                == resource.data.get('replyCount', 0) - 1);
      }

      match /posts/{pid} {
        allow read: if isSignedIn() && (
          groupVisibility(gid) == 'public'
          || isActiveMember(gid)
          || isGroupOwner(gid)
        );

        allow create: if isActiveMember(gid) && isValidPost();

        allow delete: if isSignedIn() && (
          resource.data.authorUid == request.auth.uid
          || isGroupOwner(gid)
        );

        // Content is immutable; the only permitted update is the ±1
        // replyCount bump that accompanies a reply create/delete.
        allow update: if isActiveMember(gid) && isReplyCountBumpOnly();
      }
    }

    // =========================================================
    // Denormalized "my groups" index
    // =========================================================

    function isValidUserGroupDoc() {
      return request.resource.data.keys().hasOnly([
        'role', 'status', 'joinedAt', 'groupName'
      ])
        && request.resource.data.role in ['owner', 'member']
        && request.resource.data.status in ['active', 'pending']
        && isValidTimestamp(request.resource.data.joinedAt)
        && request.resource.data.groupName is string
        && request.resource.data.groupName.size() <= 60;
    }

    match /userGroups/{uid}/groups/{gid} {
      allow read: if isSelf(uid);
      // Only the user may create their own index entry. The owner may
      // update (e.g. approve pending -> active) or delete an existing
      // entry, but cannot fabricate entries under arbitrary uids (spam).
      allow create: if isSelf(uid) && isValidUserGroupDoc();
      allow update: if (isSelf(uid) || isGroupOwner(gid))
                      && isValidUserGroupDoc();
      allow delete: if isSelf(uid) || isGroupOwner(gid);
    }

    // =========================================================
    // In-app notifications
    //
    // No Cloud Functions in v1: the actor (the replier) writes a
    // notification doc directly into each recipient's collection. The
    // create rule is locked down so a notification can ONLY be produced
    // for a real reply the actor actually made:
    //
    //   * actorName and groupName are bound to the actor's real profile
    //     name and the group's real name (read from their source docs),
    //     so the notification cannot impersonate another pilot or
    //     mislabel the group in the recipient's inbox.
    //   * postId must reference an existing post in the group that is
    //     authored by the actor and whose replyToId == topicId -- i.e. a
    //     genuine reply -- so notifications can't be fabricated without a
    //     corresponding (moderatable, deletable) reply.
    //   * the recipient must be the group owner or the topic's author.
    //
    // The recipient owns read/update(read flag)/delete on their own items.
    // Preferences (global on/off, per-group mute) live in
    // userNotificationPrefs and are applied client-side on read -- delivery
    // is not suppressed at write time.
    //
    // Residual compromise (rules-only): volume is bounded only by how many
    // real replies the actor can post. A determined active member could
    // still generate notification noise by posting many real replies; the
    // group owner moderates that by deleting the replies/member. Move to a
    // Cloud Function for true rate limiting.
    // =========================================================

    function notifTopicAuthor(gid, topicId) {
      return get(
        /databases/$(database)/documents/groups/$(gid)/posts/$(topicId)
      ).data.authorUid;
    }

    // The notification's postId must point at a real reply: a post in the
    // same group, authored by the actor, whose parent is the named topic.
    // The two get() calls resolve to the same document and are deduped at
    // evaluation time, so this costs one read plus the exists() guard.
    function notifReplyIsGenuine(gid, postId, topicId) {
      return exists(/databases/$(database)/documents/groups/$(gid)/posts/$(postId))
        && get(/databases/$(database)/documents/groups/$(gid)/posts/$(postId))
             .data.authorUid == request.auth.uid
        && get(/databases/$(database)/documents/groups/$(gid)/posts/$(postId))
             .data.get('replyToId', '') == topicId;
    }

    function isValidNotification(recipientUid) {
      return request.resource.data.keys().hasOnly([
          'type', 'groupId', 'groupName', 'topicId', 'postId',
          'actorUid', 'actorName', 'reason', 'snippet', 'read', 'createdAt'
        ])
        && request.resource.data.type == 'reply'
        && request.resource.data.groupId is string
        && request.resource.data.groupName is string
        && request.resource.data.groupName.size() <= 60
        && request.resource.data.topicId is string
        && request.resource.data.topicId.size() <= 64
        && request.resource.data.postId is string
        && request.resource.data.postId.size() <= 64
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.actorName.size() <= 60
        && request.resource.data.reason in ['topic_author', 'group_owner']
        && request.resource.data.snippet is string
        && request.resource.data.snippet.size() <= 140
        && request.resource.data.read == false
        && isValidTimestamp(request.resource.data.createdAt)
        // Actor must be an active member of the group they're notifying
        // about.
        && isActiveMember(request.resource.data.groupId)
        // Anti-impersonation: the displayed name and group label are bound
        // to their authoritative source documents, not free text.
        && request.resource.data.actorName ==
             get(/databases/$(database)/documents/users/$(request.auth.uid))
               .data.displayName
        && request.resource.data.groupName ==
             groupData(request.resource.data.groupId).name
        // Anti-fabrication: there must be a real reply backing this.
        && notifReplyIsGenuine(request.resource.data.groupId,
                               request.resource.data.postId,
                               request.resource.data.topicId)
        // The recipient must have a legitimate stake in the group.
        && (
          groupData(request.resource.data.groupId).ownerUid == recipientUid
          || notifTopicAuthor(request.resource.data.groupId,
                              request.resource.data.topicId) == recipientUid
        );
    }

    match /userNotifications/{uid}/items/{nid} {
      allow read: if isSelf(uid);
      allow create: if isSignedIn() && isValidNotification(uid);
      // Recipient may only flip the read flag; everything else is frozen.
      allow update: if isSelf(uid)
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['read'])
        && request.resource.data.read is bool;
      allow delete: if isSelf(uid);
    }

    function isValidNotificationPrefs() {
      return request.resource.data.keys().hasOnly([
          'globalEnabled', 'mutedGroupIds'
        ])
        && request.resource.data.globalEnabled is bool
        && isValidStringList(
             request.resource.data.get('mutedGroupIds', []), 500);
    }

    match /userNotificationPrefs/{uid} {
      allow read: if isSelf(uid);
      allow write: if isSelf(uid) && isValidNotificationPrefs();
    }

    // =========================================================
    // Per-user feed read markers
    //
    // Tracks the last time the user marked a group's feed as read so the
    // client can render newer topics in bold. Entirely private to the
    // user; the only field is a timestamp.
    // =========================================================

    match /userGroupReads/{uid}/groups/{gid} {
      allow read: if isSelf(uid);
      allow write: if isSelf(uid)
        && request.resource.data.keys().hasOnly(['lastReadAt'])
        && isValidTimestamp(request.resource.data.lastReadAt);
    }

    // =========================================================
    // Aircraft Scheduler
    //
    // Mirrors the Community group model: an owner creates a scheduler,
    // members join (public = immediate, private = owner-approved), the
    // owner adds schedulable resources (aircraft / instructors), and
    // members reserve those resources. Reservations carry a backup queue;
    // when a main reservation is cancelled the next backup is promoted by
    // the canceller via a constrained update (isReservationPromotion).
    //
    // Same rules-only compromises as Community apply (counter drift,
    // client-supplied timestamps, and a small booking race window).
    // =========================================================

    function schedGroupData(sgid) {
      return get(/databases/$(database)/documents/schedulerGroups/$(sgid)).data;
    }

    function isSchedOwner(sgid) {
      return isSignedIn() && schedGroupData(sgid).ownerUid == request.auth.uid;
    }

    function schedVisibility(sgid) {
      return schedGroupData(sgid).visibility;
    }

    function schedMemberData(sgid, uid) {
      return get(
        /databases/$(database)/documents/schedulerGroups/$(sgid)/members/$(uid)
      ).data;
    }

    function schedMemberExists(sgid, uid) {
      return exists(
        /databases/$(database)/documents/schedulerGroups/$(sgid)/members/$(uid)
      );
    }

    function isSchedActiveMember(sgid) {
      return isSignedIn()
        && schedMemberExists(sgid, request.auth.uid)
        && schedMemberData(sgid, request.auth.uid).status == 'active';
    }

    function isValidSchedGroupCreate() {
      return request.resource.data.keys().hasOnly([
        'name', 'nameLower', 'description', 'homeAirport', 'visibility',
        'ownerUid', 'ownerName', 'memberCount', 'resourceCount',
        'maxReservationsPerMember', 'maxWeekendReservations', 'createdAt'
      ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && isValidIcao(request.resource.data.get('homeAirport', null))
        // All schedulers are private.
        && request.resource.data.visibility == 'private'
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40
        && request.resource.data.memberCount == 1
        && request.resource.data.resourceCount == 0
        && request.resource.data.maxReservationsPerMember is int
        && request.resource.data.maxReservationsPerMember >= 0
        && request.resource.data.maxWeekendReservations is int
        && request.resource.data.maxWeekendReservations >= 0
        && isValidTimestamp(request.resource.data.createdAt);
    }

    // ±1 counter bump (memberCount on join/leave). Mirrors the Community
    // isCounterBumpOnly compromise but covers resourceCount too.
    function isSchedCounterBumpOnly() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly(['memberCount', 'resourceCount'])
        && request.resource.data.memberCount is int
        && request.resource.data.resourceCount is int
        && request.resource.data.memberCount >= 0
        && request.resource.data.resourceCount >= 0
        && (!('memberCount' in changed)
            || request.resource.data.memberCount
               == resource.data.memberCount + 1
            || request.resource.data.memberCount
               == resource.data.memberCount - 1)
        && (!('resourceCount' in changed)
            || request.resource.data.resourceCount
               == resource.data.resourceCount + 1
            || request.resource.data.resourceCount
               == resource.data.resourceCount - 1);
    }

    function isValidSchedOwnerUpdate() {
      let changed =
        request.resource.data.diff(resource.data).changedKeys();
      return request.resource.data.keys().hasOnly([
          'name', 'nameLower', 'description', 'homeAirport', 'visibility',
          'ownerUid', 'ownerName', 'memberCount', 'resourceCount',
          'maxReservationsPerMember', 'maxWeekendReservations', 'createdAt'
        ])
        && !('ownerUid' in changed)
        && !('createdAt' in changed)
        // Re-validate the same field types/lengths as create so an owner
        // can't write an oversized or wrong-typed name/description/etc.
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 60
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && isValidIcao(request.resource.data.get('homeAirport', null))
        && request.resource.data.ownerName is string
        && request.resource.data.ownerName.size() <= 40
        && request.resource.data.visibility == 'private'
        && request.resource.data.memberCount >= 0
        && request.resource.data.resourceCount >= 0
        && request.resource.data.maxReservationsPerMember is int
        && request.resource.data.maxReservationsPerMember >= 0
        && request.resource.data.maxWeekendReservations is int
        && request.resource.data.maxWeekendReservations >= 0;
    }

    match /schedulerGroups/{sgid} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidSchedGroupCreate();

      allow update: if (isSchedOwner(sgid) && isValidSchedOwnerUpdate())
                       || (isSignedIn() && isSchedCounterBumpOnly());

      allow delete: if isSchedOwner(sgid);

      // -----------------------------------------------------
      // Members
      // -----------------------------------------------------

      function isValidSchedMemberDoc() {
        return request.resource.data.keys().hasOnly([
          'displayName', 'role', 'status', 'joinedAt',
          'clubRole', 'assignedInstructorUid', 'assignedInstructorName'
        ])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 60
          && request.resource.data.role in ['owner', 'member']
          && request.resource.data.status in ['active', 'pending']
          && request.resource.data.clubRole in
               ['pilot', 'student', 'instructor', 'dispatcher']
          && (request.resource.data.get('assignedInstructorUid', null) == null
              || (request.resource.data.assignedInstructorUid is string
                  && request.resource.data.assignedInstructorUid.size() <= 128))
          && (request.resource.data.get('assignedInstructorName', null) == null
              || (request.resource.data.assignedInstructorName is string
                  && request.resource.data.assignedInstructorName.size() <= 60))
          && isValidTimestamp(request.resource.data.joinedAt);
      }

      function isSchedMemberClubRoleUpdate() {
        return request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly([
                   'clubRole',
                   'assignedInstructorUid',
                   'assignedInstructorName'
                 ])
          && request.resource.data.clubRole in
               ['pilot', 'student', 'instructor', 'dispatcher']
          && (request.resource.data.get('assignedInstructorUid', null) == null
              || (request.resource.data.assignedInstructorUid is string
                  && request.resource.data.assignedInstructorUid.size() <= 128))
          && (request.resource.data.get('assignedInstructorName', null) == null
              || (request.resource.data.assignedInstructorName is string
                  && request.resource.data.assignedInstructorName.size() <= 60));
      }

      function isSchedDispatcher() {
        return isSchedActiveMember(sgid)
          && schedMemberData(sgid, request.auth.uid).clubRole == 'dispatcher';
      }

      function canSchedDispatch() {
        return isSchedOwner(sgid) || isSchedDispatcher();
      }

      match /members/{uid} {
        allow read: if isSignedIn() && (
          isSelf(uid)
          || isSchedOwner(sgid)
          || schedVisibility(sgid) == 'public'
          || isSchedActiveMember(sgid)
        );

        allow create: if isSelf(uid) && isValidSchedMemberDoc() && (
          // Owner self-create. !exists() covers the create batch; after the
          // scheduler exists only the real owner can write an owner doc.
          (request.resource.data.role == 'owner'
           && request.resource.data.status == 'active'
           && request.resource.data.clubRole == 'dispatcher'
           && (!exists(/databases/$(database)/documents/schedulerGroups/$(sgid))
               || schedGroupData(sgid).ownerUid == request.auth.uid))

          || (request.resource.data.role == 'member'
              && schedVisibility(sgid) == 'public'
              && request.resource.data.status == 'active'
              && request.resource.data.clubRole == 'pilot')

          || (request.resource.data.role == 'member'
              && schedVisibility(sgid) == 'private'
              && request.resource.data.status == 'pending'
              && request.resource.data.clubRole == 'pilot')
        );

        allow update: if
          (isSchedOwner(sgid)
            && request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly(['status'])
            && resource.data.status == 'pending'
            && request.resource.data.status == 'active')
          || (isSchedOwner(sgid) && isSchedMemberClubRoleUpdate());

        allow delete: if isSelf(uid) || isSchedOwner(sgid);
      }

      // -----------------------------------------------------
      // Resources (owner-managed; dispatchers may update status)
      // -----------------------------------------------------

      function isValidResource() {
        return request.resource.data.keys().hasOnly([
          'name', 'type', 'identifier', 'available', 'createdAt',
          'hobbs', 'tach', 'annualDue', 'hundredHourDueHobbs',
          'transponderDue', 'eltDue', 'mxNotes'
        ])
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 40
          && request.resource.data.type in ['aircraft', 'instructor']
          && (request.resource.data.get('identifier', null) == null
              || (request.resource.data.identifier is string
                  && request.resource.data.identifier.size() <= 20))
          && request.resource.data.available is bool
          && isValidTimestamp(request.resource.data.createdAt)
          && (request.resource.data.get('hobbs', null) == null
              || request.resource.data.hobbs is number)
          && (request.resource.data.get('tach', null) == null
              || request.resource.data.tach is number)
          && (request.resource.data.get('annualDue', null) == null
              || isValidTimestamp(request.resource.data.annualDue))
          && (request.resource.data.get('hundredHourDueHobbs', null) == null
              || request.resource.data.hundredHourDueHobbs is number)
          && (request.resource.data.get('transponderDue', null) == null
              || isValidTimestamp(request.resource.data.transponderDue))
          && (request.resource.data.get('eltDue', null) == null
              || isValidTimestamp(request.resource.data.eltDue))
          && (request.resource.data.get('mxNotes', null) == null
              || (request.resource.data.mxNotes is string
                  && request.resource.data.mxNotes.size() <= 500));
      }

      match /resources/{rid} {
        allow read: if isSignedIn() && (
          schedVisibility(sgid) == 'public'
          || isSchedActiveMember(sgid)
          || isSchedOwner(sgid)
        );

        allow create: if isSchedOwner(sgid) && isValidResource();

        allow update: if canSchedDispatch() && isValidResource()
          && request.resource.data.name == resource.data.name
          && request.resource.data.type == resource.data.type
          && request.resource.data.createdAt == resource.data.createdAt;

        allow delete: if isSchedOwner(sgid);
      }

      // -----------------------------------------------------
      // Reservations
      // -----------------------------------------------------

      function isValidReservation() {
        return request.resource.data.keys().hasOnly([
          'resourceId', 'resourceName', 'schedulerUid', 'schedulerName',
          'start', 'end', 'isBackup', 'backupOrder', 'note', 'createdAt',
          'instructorUid', 'instructorName', 'studentUid', 'studentName',
          'lessonPackId'
        ])
          && request.resource.data.resourceId is string
          && request.resource.data.resourceName is string
          && request.resource.data.resourceName.size() <= 40
          && request.resource.data.schedulerUid == request.auth.uid
          && request.resource.data.schedulerName is string
          && request.resource.data.schedulerName.size() <= 40
          && isValidTimestamp(request.resource.data.start)
          && isValidTimestamp(request.resource.data.end)
          && request.resource.data.isBackup is bool
          && request.resource.data.backupOrder is int
          && request.resource.data.backupOrder >= 0
          && (request.resource.data.get('note', null) == null
              || (request.resource.data.note is string
                  && request.resource.data.note.size() <= 200))
          && (request.resource.data.get('instructorUid', null) == null
              || (request.resource.data.instructorUid is string
                  && request.resource.data.instructorUid.size() <= 128))
          && (request.resource.data.get('instructorName', null) == null
              || (request.resource.data.instructorName is string
                  && request.resource.data.instructorName.size() <= 60))
          && (request.resource.data.get('studentUid', null) == null
              || (request.resource.data.studentUid is string
                  && request.resource.data.studentUid.size() <= 128))
          && (request.resource.data.get('studentName', null) == null
              || (request.resource.data.studentName is string
                  && request.resource.data.studentName.size() <= 60))
          && (request.resource.data.get('lessonPackId', null) == null
              || (request.resource.data.lessonPackId is string
                  && request.resource.data.lessonPackId.size() <= 128))
          && isValidTimestamp(request.resource.data.createdAt);
      }

      // Promotion-only update: a backup becomes the main reservation when
      // the previous main is cancelled. The canceller (any active member)
      // may only flip isBackup false and zero backupOrder; no other field
      // may change. v1 rules-only compromise.
      function isReservationPromotion() {
        return request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly(['isBackup', 'backupOrder'])
          && resource.data.isBackup == true
          && request.resource.data.isBackup == false
          && request.resource.data.backupOrder == 0
          // The reservation must point at a resource that still exists,
          // so an orphaned/garbage doc can't be promoted to a main slot.
          && exists(/databases/$(database)/documents/schedulerGroups/$(sgid)/resources/$(resource.data.resourceId));
      }

      match /reservations/{resvId} {
        allow read: if isSignedIn() && (
          schedVisibility(sgid) == 'public'
          || isSchedActiveMember(sgid)
          || isSchedOwner(sgid)
        );

        allow create: if isSchedActiveMember(sgid) && isValidReservation();

        // The owner may promote any backup. A regular member may only
        // promote someone else's backup (the next-in-line after they
        // cancel their own main) -- never their own, which would let them
        // jump the queue or self-promote past an active main.
        allow update: if isSchedOwner(sgid)
                         || (isSchedActiveMember(sgid)
                             && resource.data.schedulerUid != request.auth.uid
                             && isReservationPromotion());

        // Only the member who booked it or the owner may cancel.
        allow delete: if isSignedIn() && (
          resource.data.schedulerUid == request.auth.uid
          || isSchedOwner(sgid)
        );
      }

      // -----------------------------------------------------
      // Squawks (discrepancy / MX reports)
      // -----------------------------------------------------

      function isValidSquawkCreate() {
        return request.resource.data.keys().hasOnly([
          'resourceId', 'resourceName', 'title', 'description',
          'severity', 'status', 'reportedByUid', 'reportedByName',
          'createdAt', 'resolvedAt', 'resolvedByUid', 'resolvedByName'
        ])
          && request.resource.data.resourceId is string
          && request.resource.data.resourceName is string
          && request.resource.data.resourceName.size() <= 40
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 80
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 500
          && request.resource.data.severity in
               ['grounding', 'caution', 'info']
          && request.resource.data.status == 'open'
          && request.resource.data.reportedByUid == request.auth.uid
          && request.resource.data.reportedByName is string
          && request.resource.data.reportedByName.size() <= 60
          && isValidTimestamp(request.resource.data.createdAt)
          && request.resource.data.resolvedAt == null
          && request.resource.data.resolvedByUid == null
          && request.resource.data.resolvedByName == null;
      }

      function isSquawkResolve() {
        return request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly([
                   'status', 'resolvedAt', 'resolvedByUid', 'resolvedByName'
                 ])
          && resource.data.status == 'open'
          && request.resource.data.status == 'resolved'
          && isValidTimestamp(request.resource.data.resolvedAt)
          && request.resource.data.resolvedByUid == request.auth.uid
          && request.resource.data.resolvedByName is string
          && request.resource.data.resolvedByName.size() <= 60;
      }

      match /squawks/{sid} {
        allow read: if isSignedIn() && (
          isSchedActiveMember(sgid) || isSchedOwner(sgid)
        );

        allow create: if isSchedActiveMember(sgid) && isValidSquawkCreate();

        allow update: if isSchedActiveMember(sgid) && isSquawkResolve() && (
          canSchedDispatch()
          || resource.data.reportedByUid == request.auth.uid
        );

        allow delete: if canSchedDispatch();
      }

      // -----------------------------------------------------
      // Lesson packs (prepaid student hours)
      // -----------------------------------------------------

      function isValidLessonPack() {
        return request.resource.data.keys().hasOnly([
          'name', 'description', 'totalHours', 'hoursUsed',
          'studentUid', 'studentName', 'instructorUid', 'instructorName',
          'status', 'createdAt', 'expiresAt'
        ])
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 60
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 280
          && request.resource.data.totalHours is number
          && request.resource.data.totalHours > 0
          && request.resource.data.hoursUsed is number
          && request.resource.data.hoursUsed >= 0
          && request.resource.data.studentUid is string
          && request.resource.data.studentUid.size() <= 128
          && request.resource.data.studentName is string
          && request.resource.data.studentName.size() <= 60
          && (request.resource.data.get('instructorUid', null) == null
              || (request.resource.data.instructorUid is string
                  && request.resource.data.instructorUid.size() <= 128))
          && (request.resource.data.get('instructorName', null) == null
              || (request.resource.data.instructorName is string
                  && request.resource.data.instructorName.size() <= 60))
          && request.resource.data.status in
               ['active', 'completed', 'cancelled']
          && isValidTimestamp(request.resource.data.createdAt)
          && (request.resource.data.get('expiresAt', null) == null
              || isValidTimestamp(request.resource.data.expiresAt));
      }

      function isLessonPackHoursLog() {
        return request.resource.data.diff(resource.data).changedKeys()
                 .hasOnly(['hoursUsed', 'status'])
          && request.resource.data.hoursUsed is number
          && request.resource.data.hoursUsed >= resource.data.hoursUsed
          && request.resource.data.status in
               ['active', 'completed', 'cancelled'];
      }

      match /lessonPacks/{pid} {
        allow read: if isSignedIn() && (
          isSchedActiveMember(sgid) || isSchedOwner(sgid)
        );

        allow create: if isSchedOwner(sgid) && isValidLessonPack()
          && request.resource.data.hoursUsed == 0
          && request.resource.data.status == 'active';

        allow update: if isValidLessonPack() && (
          isSchedOwner(sgid)
          || (isSchedActiveMember(sgid)
              && isLessonPackHoursLog()
              && (canSchedDispatch()
                  || resource.data.studentUid == request.auth.uid
                  || resource.data.instructorUid == request.auth.uid))
        );

        allow delete: if isSchedOwner(sgid);
      }
    }

    function isValidUserSchedGroupDoc() {
      return request.resource.data.keys().hasOnly([
        'role', 'status', 'joinedAt', 'groupName'
      ])
        && request.resource.data.role in ['owner', 'member']
        && request.resource.data.status in ['active', 'pending']
        && isValidTimestamp(request.resource.data.joinedAt)
        && request.resource.data.groupName is string
        && request.resource.data.groupName.size() <= 60;
    }

    match /userSchedulerGroups/{uid}/groups/{sgid} {
      allow read: if isSelf(uid);
      // Only the user may create their own index entry. The owner may
      // update (e.g. approve pending -> active) or delete an existing
      // entry, but cannot fabricate entries under arbitrary uids (spam).
      allow create: if isSelf(uid) && isValidUserSchedGroupDoc();
      allow update: if (isSelf(uid) || isSchedOwner(sgid))
                      && isValidUserSchedGroupDoc();
      allow delete: if isSelf(uid) || isSchedOwner(sgid);
    }

    // =========================================================
    // Airport Businesses (crowd-sourced FBO directory + reviews)
    //
    // Business *names* are seeded by an offline import that runs through the
    // Admin SDK (which bypasses these rules). Everything else -- services,
    // fuel, hours and reviews -- is contributed by signed-in pilots from
    // inside the app.
    //
    // Anti-junk / accountability model:
    //   * Nothing is anonymous: createdByName (listings) and authorName
    //     (reviews) are bound to the contributor's authoritative profile
    //     display name (users/{uid}.displayName), so they can't be spoofed
    //     to a different pilot.
    //   * Nothing can be deleted: allow delete is false for both listings
    //     and reviews, and reviews are additionally immutable. This keeps a
    //     durable, attributable record and prevents review-bombing cleanup
    //     abuse. Moderation of bad content is an admin/offline task.
    //   * Detail edits (services/fuel/hours) are open to any signed-in
    //     contributor (the data is community-owned), but the listing's
    //     identity, creator and aggregate counters are frozen on that path.
    //     Each edit is attributed (lastEditedByUid/Name bound to the editor's
    //     profile) so detail changes are no longer anonymous.
    //   * Review aggregates are NOT stored on the listing (there is no
    //     reviewCount/ratingSum field to forge). The displayed average and
    //     count are computed on the client with Firestore aggregation
    //     queries (count() / average('rating')) directly over the immutable
    //     reviews subcollection, so a rating can only reflect real,
    //     attributable review documents. This keeps the feature rules-only
    //     (no Cloud Functions), consistent with the rest of this file.
    //   * All client-set timestamps (createdAt / updatedAt / lastReviewedAt)
    //     are pinned to request.time so ordering (e.g. newest reviews, or
    //     floating interacted listings to the top) can't be spoofed.
    //   * lastReviewedAt is stamped on the listing when a review is posted so
    //     reviewed listings can be floated to the top without counting the
    //     reviews subcollection on read; it affects ordering only.
    // =========================================================

    function profileName(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.displayName;
    }

    function isValidBusinessStringList(v, maxItems) {
      return v is list
        && v.size() <= maxItems
        && v.toSet().size() == v.size();
    }

    // Optional map coordinate. Absent for most user-added listings; present
    // for seeded ones. When present both parts must be valid numbers in range.
    function isValidBusinessLocation() {
      let d = request.resource.data;
      return (d.get('latitude', null) == null && d.get('longitude', null) == null)
        || (d.latitude is number && d.latitude >= -90 && d.latitude <= 90
            && d.longitude is number && d.longitude >= -180 && d.longitude <= 180);
    }

    function isValidBusinessCreate() {
      return request.resource.data.keys().hasOnly([
          'airport', 'name', 'nameLower', 'services', 'fuelTypes',
          'operatingHours', 'phoneNumber', 'radioFrequency',
          'createdByUid', 'createdByName', 'source', 'createdAt',
          'latitude', 'longitude'
        ])
        && request.resource.data.airport is string
        && request.resource.data.airport.size() >= 2
        && request.resource.data.airport.size() <= 8
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.nameLower is string
        && request.resource.data.nameLower == request.resource.data.name.lower()
        && isValidBusinessStringList(request.resource.data.services, 30)
        && isValidBusinessStringList(request.resource.data.fuelTypes, 10)
        && request.resource.data.operatingHours is string
        && request.resource.data.operatingHours.size() <= 200
        && request.resource.data.get('phoneNumber', '') is string
        && request.resource.data.get('phoneNumber', '').size() <= 30
        && request.resource.data.get('radioFrequency', '') is string
        && request.resource.data.get('radioFrequency', '').size() <= 30
        && isValidBusinessLocation()
        && request.resource.data.createdByUid == request.auth.uid
        // Bind the shown contributor name to the profile so it can't be
        // spoofed to another pilot -- this is what makes listings
        // accountable rather than anonymous.
        && request.resource.data.createdByName == profileName(request.auth.uid)
        && request.resource.data.source == 'user'
        // Pin creation time to the server clock (no client-chosen ordering).
        && request.resource.data.createdAt == request.time;
    }

    // Detail-only edit: services / fuel / hours may change; identity,
    // creator, source, name and review aggregates are all frozen. Every edit
    // must carry the editor's attribution (bound to their profile) and a
    // server-pinned updatedAt, so detail changes are accountable.
    function isValidBusinessDetailUpdate() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly([
          'services', 'fuelTypes', 'operatingHours', 'phoneNumber',
          'radioFrequency', 'fuelPrices',
          'lastEditedByUid', 'lastEditedByName', 'updatedAt'
        ])
        && isValidBusinessStringList(request.resource.data.services, 30)
        && isValidBusinessStringList(request.resource.data.fuelTypes, 10)
        && request.resource.data.operatingHours is string
        && request.resource.data.operatingHours.size() <= 200
        && request.resource.data.get('phoneNumber', '') is string
        && request.resource.data.get('phoneNumber', '').size() <= 30
        && request.resource.data.get('radioFrequency', '') is string
        && request.resource.data.get('radioFrequency', '').size() <= 30
        // fuelPrices is a map keyed by fuel type; per-entry shape (number
        // price + timestamp) is sanitized client-side (rules can't iterate
        // map values), but the map size is capped here.
        && request.resource.data.get('fuelPrices', {}) is map
        && request.resource.data.get('fuelPrices', {}).size() <= 12
        && request.resource.data.lastEditedByUid == request.auth.uid
        && request.resource.data.lastEditedByName == profileName(request.auth.uid)
        && request.resource.data.updatedAt == request.time;
    }

    // Review-activity bump: when a pilot posts a review (in the same batch)
    // the listing's lastReviewedAt is stamped so reviewed listings can float
    // to the top of the lists without counting the reviews subcollection on
    // read. Only that one field may change and it must equal request.time.
    //
    // Rules-only compromise (mirrors the counter-bump pattern elsewhere in
    // this file): rules can't prove the bump is paired with a real review
    // write, so a signed-in user could re-stamp lastReviewedAt without a new
    // review. The only effect is list ordering, so the impact is cosmetic.
    function isBusinessReviewActivityBump() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly(['lastReviewedAt'])
        && request.resource.data.lastReviewedAt == request.time;
    }

    function isValidBusinessReview() {
      return request.resource.data.keys().hasOnly([
          'rating', 'text', 'authorUid', 'authorName', 'createdAt'
        ])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000
        && request.resource.data.authorUid == request.auth.uid
        // Bind the review's author name to the profile (no anonymous /
        // impersonated reviews).
        && request.resource.data.authorName == profileName(request.auth.uid)
        // Pin creation time to the server clock (no client-chosen ordering).
        && request.resource.data.createdAt == request.time;
    }

    match /airportBusinesses/{bizId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidBusinessCreate();

      // Two client-writable mutations: an attributed detail edit, or the
      // single-field lastReviewedAt bump that accompanies posting a review.
      // Review aggregates (count/average) are still computed on read from the
      // reviews subcollection; lastReviewedAt only affects list ordering.
      allow update: if isSignedIn()
        && (isValidBusinessDetailUpdate() || isBusinessReviewActivityBump());

      // Listings are permanent -- accountability over deletability.
      allow delete: if false;

      match /reviews/{rid} {
        allow read: if isSignedIn();
        // One review per pilot per business: the review doc id must be the
        // author's uid. A second review would target the same (immutable) doc
        // and be rejected, which also caps review spam and rating gaming.
        allow create: if isSignedIn()
          && rid == request.auth.uid
          && isValidBusinessReview();
        // Reviews are immutable and permanent.
        allow update, delete: if false;
      }
    }
  }
}
