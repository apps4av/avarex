rules_version = '2';

// Firebase Storage rules for AvareX.
//
// Deploy with:
//   firebase deploy --only storage
//
// (Add a "storage" section to firebase.json:
//    "storage": { "rules": "storage.rules" })

service firebase.storage {
  match /b/{bucket}/o {

    // ------------------------------------------------------------------
    // Backup / Restore
    //
    // user.db and other per-user files live at users/{uid}/**.
    // Only the authenticated owner can read, write, or delete their
    // own files — backups are private. The client always accesses
    // these objects with an authenticated FirebaseStorage SDK call
    // against gs:// paths (see lib/services/backup_screen.dart), so
    // no public-read path is needed.
    // ------------------------------------------------------------------
    match /users/{userId}/{allPaths=**} {
      allow read, delete: if request.auth != null
                         && request.auth.uid == userId;

      allow write, create: if request.auth != null
                          && request.auth.uid == userId
                          && request.resource.size < 10 * 1024 * 1024;
    }

    // ------------------------------------------------------------------
    // Community (Pilot Community feature)
    //
    // Photos attached to group posts live at
    //   community/{groupId}/{uid}/{postId}/{filename}
    //
    // The {uid} segment is the uploader, which lets these rules bind a
    // file to its owner without consulting the (not-yet-written) post
    // doc. Access is gated against the group in Firestore:
    //   * read   -> public group, OR active member, OR group owner
    //   * write  -> the uploader, who must be an active member; image
    //               files only, under 5 MB
    //   * delete -> the uploader OR the group owner (cleanup)
    //
    // NOTE: A Firebase download URL carries a capability token that
    // bypasses these rules for HTTPS reads; that token only lives in the
    // access-controlled post doc. These rules close the gs:// SDK path
    // enumeration / overwrite / vandalism holes.
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function communityGroup(groupId) {
      return firestore.get(/databases/(default)/documents/groups/$(groupId)).data;
    }

    function communityGroupExists(groupId) {
      return firestore.exists(/databases/(default)/documents/groups/$(groupId));
    }

    function isCommunityOwner(groupId) {
      return isSignedIn()
        && communityGroupExists(groupId)
        && communityGroup(groupId).ownerUid == request.auth.uid;
    }

    function isCommunityPublic(groupId) {
      return communityGroupExists(groupId)
        && communityGroup(groupId).visibility == 'public';
    }

    function isActiveCommunityMember(groupId) {
      return isSignedIn()
        && firestore.exists(
             /databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid))
        && firestore.get(
             /databases/(default)/documents/groups/$(groupId)/members/$(request.auth.uid))
             .data.status == 'active';
    }

    match /community/{groupId}/{uid}/{postId}/{filename} {
      allow read: if isSignedIn() && (
        isCommunityPublic(groupId)
        || isActiveCommunityMember(groupId)
        || isCommunityOwner(groupId)
      );

      allow write: if isSignedIn()
                  && request.auth.uid == uid
                  && isActiveCommunityMember(groupId)
                  && request.resource.size < 5 * 1024 * 1024
                  && request.resource.contentType.matches('image/.*');

      allow delete: if isSignedIn()
                   && (request.auth.uid == uid || isCommunityOwner(groupId));
    }
  }
}
